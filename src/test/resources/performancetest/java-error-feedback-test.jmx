          <hashTree/>
          <JSONPathAssertion guiclass="JSONPathAssertionGui" testclass="JSONPathAssertion" testname="Assert plainLanguageExplanation exists">
            <stringProp name="JSON_PATH">$.plainLanguageExplanation</stringProp>
            <stringProp name="EXPECTED_VALUE"></stringProp>
