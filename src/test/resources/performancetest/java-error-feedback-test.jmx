            <boolProp name="EXPECT_NULL">false</boolProp>
            <boolProp name="INVERT">false</boolProp>
            <boolProp name="ISREGEX">false</boolProp>
          </JSONPathAssertion>
          <hashTree/>
          <JSONPathAssertion guiclass="JSONPathAssertionGui" testclass="JSONPathAssertion" testname="Assert suggestedFix exists">
            <stringProp name="JSON_PATH">$.suggestedFix</stringProp>
            <stringProp name="EXPECTED_VALUE"></stringProp>
